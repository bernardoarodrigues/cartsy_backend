DATABASE_URL=postgresql://cartsy:cartsy@localhost:5432/cartsy_matcher
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CARTSY_ML_MODEL_PATH=models/cartsy_logreg.joblib
# LLM attribute extraction is currently disabled in the pipeline. Strong exact
# evidence can merge when no contradiction exists; logistic regression handles
# borderline candidate pairs.
OPENAI_EXTRACTION_MODEL=gpt-5.4-nano
# Keep smoke runs cheap. Increase or unset for fuller semantic coverage.
CARTSY_EMBEDDING_BATCH_SIZE=128
CARTSY_LLM_EXTRACTION_LIMIT=0
# Recall-oriented retrieval fanout per product per layer.
CARTSY_FTS_CANDIDATES=25
CARTSY_TRIGRAM_CANDIDATES=25
CARTSY_TRIGRAM_MIN_SIMILARITY=0.55
CARTSY_VECTOR_CANDIDATES=25

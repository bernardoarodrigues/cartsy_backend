# URL for Postgres
DATABASE_URL=postgresql://cartsy:cartsy@localhost:5432/cartsy_matcher

# openai or sentence-transformers (local MiniLM and similar)
CARTSY_EMBEDDING_PROVIDER=openai
# Required when CARTSY_EMBEDDING_PROVIDER=openai; unused for sentence-transformers
OPENAI_API_KEY=
# Model id for the chosen provider
CARTSY_EMBEDDING_MODEL=text-embedding-3-small
# Vector column width; must match model (e.g. 1536 for text-embedding-3-small, 384 for all-MiniLM-L6-v2)
CARTSY_EMBEDDING_DIMENSIONS=1536
# Texts per request (OpenAI) or batch when embedding products
CARTSY_EMBEDDING_BATCH_SIZE=128

# Max full-text search candidates per product per retrieval layer
CARTSY_FTS_CANDIDATES=25
# Max trigram similarity candidates per product per layer
CARTSY_TRIGRAM_CANDIDATES=25
# Minimum trigram score to keep a candidate in that layer
CARTSY_TRIGRAM_MIN_SIMILARITY=0.55
# Max vector (embedding) nearest-neighbor candidates per product per layer
CARTSY_VECTOR_CANDIDATES=25

# Default path to the trained sklearn classifier used for pair scoring
CARTSY_ML_MODEL_PATH=models/train_20260502_130136_final_submission/cartsy_logreg.joblib

# Persist intermediate pipeline stage outputs under the pipeline cache root
CARTSY_STAGE_CACHE_ENABLED=true
# Reuse stored embeddings for products instead of recomputing when inputs match
CARTSY_EMBEDDING_CACHE_ENABLED=true
# Root for stage and embedding caches (defaults to .cache/cartsy-dedupe if unset)
CARTSY_PIPELINE_CACHE_DIR=.cache/cartsy-dedupe

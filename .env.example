DATABASE_URL=postgresql://cartsy:cartsy@localhost:5432/cartsy_matcher
CARTSY_EMBEDDING_PROVIDER=openai
CARTSY_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
# Required pgvector width. Use 1536 for text-embedding-3-small or 384 for all-MiniLM-L6-v2.
CARTSY_EMBEDDING_DIMENSIONS=1536
CARTSY_ML_MODEL_PATH=models/final_submission/cartsy_logreg.joblib
CARTSY_EMBEDDING_BATCH_SIZE=128
# Stage caches are enabled by default and stored under CARTSY_PIPELINE_CACHE_DIR or .cache/cartsy-dedupe.
CARTSY_STAGE_CACHE_ENABLED=true
CARTSY_EMBEDDING_CACHE_ENABLED=true
CARTSY_PIPELINE_CACHE_DIR=.cache/cartsy-dedupe
# Retrieval fanout per product per layer.
CARTSY_FTS_CANDIDATES=25
CARTSY_TRIGRAM_CANDIDATES=25
CARTSY_TRIGRAM_MIN_SIMILARITY=0.55
CARTSY_VECTOR_CANDIDATES=25

digraph TrainingPipeline {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.5",
    ranksep="0.75",
    fontname="Helvetica",
    labelloc="t",
    label=<<FONT POINT-SIZE="24"><B>Cartsy Supervised Pairwise Training Pipeline</B></FONT>>
  ];

  node [
    shape=rect,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    color="#2f3a45",
    penwidth=1.4,
    margin="0.14,0.10"
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#4c566a",
    arrowsize=0.8,
    penwidth=1.2
  ];

  products [
    label=<<B>Raw Products</B><BR/>products.csv>,
    fillcolor="#eaf2ff"
  ];

  labels [
    label=<<B>Ground Truth Labels</B><BR/>ground_truth_merged.csv<BR/>source_id -&gt; deduped_id>,
    fillcolor="#eaf2ff"
  ];

  augment [
    label=<<B>1. Controlled Augmentation</B><BR/>positive duplicates preserve<BR/>variant signatures<BR/>hard negatives inject<BR/>weak shared IDs + conflicts>,
    fillcolor="#eef7ed"
  ];

  augmented [
    label=<<B>Augmented Training Files</B><BR/>dataset_merged_augmented.csv<BR/>ground_truth_merged_augmented.csv<BR/>augmentation_manifest_merged.csv>,
    fillcolor="#eef7ed"
  ];

  pair_build [
    label=<<B>2. Build Labeled Pairs</B><BR/>positive same deduped_id<BR/>hard negatives from IDs/brand/random<BR/>caps keep training tractable>,
    fillcolor="#fff4df"
  ];

  block_keys [
    label=<<B>Retrieval-Like Evidence</B><BR/>exact identifiers<BR/>FTS/trigram estimates<BR/>vector cosine block keys>,
    fillcolor="#fff9e8"
  ];

  embeddings [
    label=<<B>Optional Embeddings</B><BR/>--use-embeddings<BR/>reuse product embedding caches<BR/>compute semantic_sim>,
    fillcolor="#fceff5"
  ];

  features [
    label=<<B>3. Feature Generation</B><BR/>DEFAULT_FEATURE_COLUMNS<BR/>identifier, lexical, semantic,<BR/>size/pack/price, rule,<BR/>variant/kit/form contradictions>,
    fillcolor="#edf7f7"
  ];

  filter [
    label=<<B>Policy Alignment Filter</B><BR/>remove positive pairs with<BR/>hard contradiction features<BR/>write filtered_positive_contradictions.csv>,
    fillcolor="#fff0ec"
  ];

  splits [
    label=<<B>4. Train / Calibrate / Test</B><BR/>standard scaling<BR/>logistic regression<BR/>isotonic calibration<BR/>fallback for small datasets>,
    fillcolor="#f3efff"
  ];

  threshold [
    label=<<B>5. Threshold Selection</B><BR/>precision-constrained F1<BR/>recall guard<BR/>lower threshold wins ties<BR/>record unmet floors explicitly>,
    shape=diamond,
    width=2.65,
    height=1.55,
    fillcolor="#ffe8cc"
  ];

  diagnostics [
    label=<<B>6. Diagnostics</B><BR/>metrics.json<BR/>threshold curves<BR/>feature coefficients<BR/>false positives / negatives<BR/>top risky clusters>,
    fillcolor="#f7f7f7"
  ];

  bundle [
    label=<<B>Final Model Bundle</B><BR/>models/final_submission/<BR/>cartsy_logreg.joblib<BR/>metrics + compact diagnostics>,
    shape=component,
    fillcolor="#e8f7ff"
  ];

  runtime [
    label=<<B>Runtime Dedupe Pipeline</B><BR/>load bundle<BR/>validate feature columns<BR/>produce ml_score + threshold>,
    fillcolor="#edf1ff"
  ];

  eval [
    label=<<B>Post-Run Evaluation</B><BR/>evaluate-run on completed artifacts<BR/>precision/recall/F1<BR/>vector-only and generic-brand slices>,
    fillcolor="#f0f8ff"
  ];

  products -> augment;
  labels -> augment;
  augment -> augmented;
  augmented -> pair_build;
  pair_build -> block_keys;
  block_keys -> features;
  augmented -> embeddings;
  embeddings -> features [label="semantic_sim"];
  pair_build -> features [label="pair labels"];
  features -> filter;
  filter -> splits;
  splits -> threshold;
  threshold -> diagnostics;
  splits -> diagnostics;
  diagnostics -> bundle;
  threshold -> bundle [label="saved threshold"];
  bundle -> runtime;
  runtime -> eval;
  labels -> eval [style=dashed, label="acceptance labels"];
}

digraph DedupePipeline {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.5",
    ranksep="0.75",
    fontname="Helvetica",
    labelloc="t",
    label=<<FONT POINT-SIZE="24"><B>Cartsy Runtime Dedupe Pipeline</B></FONT>>
  ];

  node [
    shape=rect,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    color="#2f3a45",
    penwidth=1.4,
    margin="0.14,0.10"
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#4c566a",
    arrowsize=0.8,
    penwidth=1.2
  ];

  input [
    label=<<B>Raw Product CSV</B><BR/>cartsy-dedupe run>,
    fillcolor="#eaf2ff"
  ];

  normalize [
    label=<<B>1. Ingest + Normalize</B><BR/>canonical schema<BR/>brand/title/category/specs<BR/>IDs, URL keys, size, pack,<BR/>model tokens, quality flags>,
    fillcolor="#eef7ed"
  ];

  postgres [
    label=<<B>Postgres Working Tables</B><BR/>normalized products<BR/>exact keys<BR/>retrieval helper columns<BR/>embedding vectors>,
    fillcolor="#f3efff"
  ];

  exact [
    label=<<B>2a. Exact Retrieval</B><BR/>EAN/GTIN/UPC<BR/>ASIN<BR/>same-retailer SKU<BR/>trusted canonical URLs>,
    fillcolor="#fff4df"
  ];

  lexical [
    label=<<B>2b. Lexical Retrieval</B><BR/>brand-aware Postgres FTS<BR/>weighted title/category/specs>,
    fillcolor="#fff4df"
  ];

  trigram [
    label=<<B>2c. Trigram Retrieval</B><BR/>pg_trgm title similarity<BR/>inside normalized brand blocks>,
    fillcolor="#fff4df"
  ];

  vector [
    label=<<B>2d. Evidence-Gated Vector</B><BR/>pgvector cosine search<BR/>only rows with cheap signal<BR/>enter vector fanout>,
    fillcolor="#fff4df"
  ];

  pair_blocks [
    label=<<B>Candidate Pair Evidence</B><BR/>exact:* | lexical:fts<BR/>trigram:title | vector:cosine>,
    fillcolor="#fff9e8"
  ];

  semantic [
    label=<<B>3. Dense Semantic Similarity</B><BR/>embed candidate-pair products<BR/>compute pairwise cosine<BR/>semantic_sim>,
    fillcolor="#fceff5"
  ];

  features [
    label=<<B>4. Pairwise Feature Contract</B><BR/>DEFAULT_FEATURE_COLUMNS<BR/>identifier, lexical, semantic,<BR/>size/pack/price, variant,<BR/>kit/form contradiction signals>,
    fillcolor="#edf7f7"
  ];

  rules [
    label=<<B>5. Rule Chain</B><BR/>CERTAIN_BLOCK<BR/>CERTAIN_MATCH<BR/>STRONG_MATCH<BR/>LIKELY_MATCH<BR/>UNCERTAIN>,
    fillcolor="#fff0ec"
  ];

  ml [
    label=<<B>Calibrated Logistic Model</B><BR/>models/final_submission/<BR/>cartsy_logreg.joblib<BR/>ml_score + threshold>,
    shape=component,
    fillcolor="#e8f7ff"
  ];

  evidence [
    label=<<B>Evidence Score</B><BR/>multi-signal confidence<BR/>exact + lexical + trigram<BR/>semantic + rule features<BR/>penalized by contradictions>,
    fillcolor="#edf7f7"
  ];

  decision [
    label=<<B>Merge Policy</B><BR/>hard blocks stop merges<BR/>certain exacts may fast-path<BR/>otherwise require:<BR/>ml_score &gt;= threshold<BR/>AND evidence_score &gt;= floor>,
    shape=diamond,
    width=2.7,
    height=1.75,
    fillcolor="#ffe8cc"
  ];

  clustering [
    label=<<B>6. Cluster Accepted Edges</B><BR/>union connected components<BR/>cluster-level contradiction guards<BR/>stable SHA1 dedupe_id>,
    fillcolor="#edf1ff"
  ];

  artifacts [
    label=<<B>Run Artifacts</B><BR/>normalized_products.parquet<BR/>candidate_pairs.parquet<BR/>product_assignments.csv<BR/>dedupe_groups.jsonl<BR/>near_miss_pairs.csv<BR/>summary_report.json>,
    fillcolor="#f7f7f7"
  ];

  query [
    label=<<B>Query Surfaces</B><BR/>search / group / explain<BR/>index-artifacts / search-artifacts<BR/>optional FastAPI server>,
    fillcolor="#f2f2f2"
  ];

  evaluation [
    label=<<B>Post-Run Evaluation</B><BR/>evaluate-run against labels<BR/>precision/recall/F1<BR/>risk slices + gates>,
    fillcolor="#f0f8ff"
  ];

  cache [
    label=<<B>Caching</B><BR/>normalization<BR/>per-layer retrieval<BR/>scoring + clustering<BR/>product embeddings>,
    shape=folder,
    fillcolor="#eef0f2"
  ];

  config [
    label=<<B>Runtime Config</B><BR/>.env<BR/>DATABASE_URL<BR/>embedding backend/dimensions<BR/>retrieval fanout<BR/>model path + thresholds>,
    shape=note,
    fillcolor="#f8f0ff"
  ];

  input -> normalize;
  normalize -> postgres;
  postgres -> exact;
  postgres -> lexical;
  postgres -> trigram;
  postgres -> vector;
  exact -> pair_blocks;
  lexical -> pair_blocks;
  trigram -> pair_blocks;
  vector -> pair_blocks;
  pair_blocks -> semantic [label="candidate products"];
  pair_blocks -> features [label="retrieval evidence"];
  semantic -> features [label="semantic_sim"];
  features -> rules;
  features -> ml;
  features -> evidence;
  rules -> decision;
  ml -> decision;
  evidence -> decision;
  decision -> clustering [label="accepted merge edges"];
  clustering -> artifacts;
  artifacts -> query;
  artifacts -> evaluation;

  config -> postgres [style=dashed];
  config -> vector [style=dashed];
  config -> ml [style=dashed];
  config -> decision [style=dashed];

  cache -> normalize [style=dotted];
  cache -> exact [style=dotted];
  cache -> lexical [style=dotted];
  cache -> trigram [style=dotted];
  cache -> vector [style=dotted];
  cache -> semantic [style=dotted];
  cache -> decision [style=dotted];
  cache -> clustering [style=dotted];
}

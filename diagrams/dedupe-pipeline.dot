digraph DedupePipeline {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.5",
    ranksep="0.75",
    fontname="Helvetica",
    labelloc="t",
    label="Cartsy Runtime Dedupe Pipeline"
  ];

  node [
    shape=rect,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    color="#2f3a45",
    penwidth=1.4,
    margin="0.14,0.10"
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#4c566a",
    arrowsize=0.8,
    penwidth=1.2
  ];

  input [
    label="Raw Product CSV\ncartsy-dedupe run",
    fillcolor="#eaf2ff"
  ];

  normalize [
    label="1. Ingest + Normalize\ncanonical schema\nbrand/title/category/specs\nIDs, URL keys, size, pack,\nmodel tokens, quality flags",
    fillcolor="#eef7ed"
  ];

  postgres [
    label="Postgres Working Tables\nnormalized products\nexact keys\nretrieval helper columns\nembedding vectors",
    fillcolor="#f3efff"
  ];

  exact [
    label="2a. Exact Retrieval\nEAN/GTIN/UPC\nASIN\nsame-retailer SKU\ntrusted canonical URLs",
    fillcolor="#fff4df"
  ];

  lexical [
    label="2b. Lexical Retrieval\nbrand-aware Postgres FTS\nweighted title/category/specs",
    fillcolor="#fff4df"
  ];

  trigram [
    label="2c. Trigram Retrieval\npg_trgm title similarity\ninside normalized brand blocks",
    fillcolor="#fff4df"
  ];

  vector [
    label="2d. Evidence-Gated Vector\npgvector cosine search\nonly rows with cheap signal\nenter vector fanout",
    fillcolor="#fff4df"
  ];

  pair_blocks [
    label="Candidate Pair Evidence\nexact:* | lexical:fts\ntrigram:title | vector:cosine",
    fillcolor="#fff9e8"
  ];

  semantic [
    label="3. Dense Semantic Similarity\nembed candidate-pair products\ncompute pairwise cosine\nsemantic_sim",
    fillcolor="#fceff5"
  ];

  features [
    label="4. Pairwise Feature Contract\nDEFAULT_FEATURE_COLUMNS\nidentifier, lexical, semantic,\nsize/pack/price, variant,\nkit/form contradiction signals",
    fillcolor="#edf7f7"
  ];

  rules [
    label="5. Rule Chain\nCERTAIN_BLOCK\nCERTAIN_MATCH\nSTRONG_MATCH\nLIKELY_MATCH\nUNCERTAIN",
    fillcolor="#fff0ec"
  ];

  ml [
    label="Calibrated Logistic Model\nmodels/final_submission/\ncartsy_logreg.joblib\nml_score + threshold",
    shape=component,
    fillcolor="#e8f7ff"
  ];

  evidence [
    label="Evidence Score\nmulti-signal confidence\nexact + lexical + trigram\nsemantic + rule features\npenalized by contradictions",
    fillcolor="#edf7f7"
  ];

  decision [
    label="Merge Policy\nhard blocks stop merges\ncertain exacts may fast-path\notherwise require:\nml_score >= threshold\nAND evidence_score >= floor",
    shape=diamond,
    width=2.7,
    height=1.75,
    fillcolor="#ffe8cc"
  ];

  clustering [
    label="6. Cluster Accepted Edges\nunion connected components\ncluster-level contradiction guards\nstable SHA1 dedupe_id",
    fillcolor="#edf1ff"
  ];

  artifacts [
    label="Run Artifacts\nnormalized_products.parquet\ncandidate_pairs.parquet\nproduct_assignments.csv\ndedupe_groups.jsonl\nnear_miss_pairs.csv\nsummary_report.json",
    fillcolor="#f7f7f7"
  ];

  query [
    label="Query Surfaces\nsearch / group / explain\nindex-artifacts / search-artifacts\noptional FastAPI server",
    fillcolor="#f2f2f2"
  ];

  evaluation [
    label="Post-Run Evaluation\nevaluate-run against labels\nprecision/recall/F1\nrisk slices + gates",
    fillcolor="#f0f8ff"
  ];

  cache [
    label="Caching\nnormalization\nper-layer retrieval\nscoring + clustering\nproduct embeddings",
    shape=folder,
    fillcolor="#eef0f2"
  ];

  config [
    label="Runtime Config\n.env\nDATABASE_URL\nembedding backend/dimensions\nretrieval fanout\nmodel path + thresholds",
    shape=note,
    fillcolor="#f8f0ff"
  ];

  input -> normalize;
  normalize -> postgres;
  postgres -> exact;
  postgres -> lexical;
  postgres -> trigram;
  postgres -> vector;
  exact -> pair_blocks;
  lexical -> pair_blocks;
  trigram -> pair_blocks;
  vector -> pair_blocks;
  pair_blocks -> semantic [label="candidate products"];
  pair_blocks -> features [label="retrieval evidence"];
  semantic -> features [label="semantic_sim"];
  features -> rules;
  features -> ml;
  features -> evidence;
  rules -> decision;
  ml -> decision;
  evidence -> decision;
  decision -> clustering [label="accepted merge edges"];
  clustering -> artifacts;
  artifacts -> query;
  artifacts -> evaluation;

  config -> postgres [style=dashed];
  config -> vector [style=dashed];
  config -> ml [style=dashed];
  config -> decision [style=dashed];

  cache -> normalize [style=dotted];
  cache -> exact [style=dotted];
  cache -> lexical [style=dotted];
  cache -> trigram [style=dotted];
  cache -> vector [style=dotted];
  cache -> semantic [style=dotted];
  cache -> decision [style=dotted];
  cache -> clustering [style=dotted];
}
